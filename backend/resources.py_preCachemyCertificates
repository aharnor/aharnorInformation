# Read All certificate files
# Robust path resolution
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DATA_DIR = os.path.join(BASE_DIR, "data")
cert_pattern = os.path.join(DATA_DIR, "certificate_*.pdf")
cert_files = glob.glob(cert_pattern)
myCertificates = ""

if cert_files:
    print(f"Found {len(cert_files)} certificate files to process.")
    for file_path in cert_files:
        try:
            reader = PdfReader(file_path)
            text = ""
            for page in reader.pages:
                extracted = page.extract_text()
                if extracted:
                    text += extracted + "\n"
            
            if not text.strip():
                print(f"No digital text found in {os.path.basename(file_path)}. Running OCR...")
                images = convert_from_path(file_path)
                for img in images:
                    text += pytesseract.image_to_string(img) + "\n"
            
            if text.strip():
                myCertificates += text + "\n"
                print(f"Successfully processed: {os.path.basename(file_path)} (Length: {len(text)} chars)")
            else:
                print(f"Warning: Could not extract any text from {os.path.basename(file_path)}")
                
